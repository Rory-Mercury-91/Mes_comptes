# Supabase — https://supabase.com/dashboard/project/karjavjcevpfeojkwywy/settings/api
VITE_SUPABASE_URL=https://karjavjcevpfeojkwywy.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_ici

# Ne jamais committer la clé service_role dans le client.
#
# CI GitHub Actions : créer aussi ces secrets (Settings > Secrets > Actions)
# à partir des mêmes valeurs que votre .env local :
#   VITE_SUPABASE_URL
#   VITE_SUPABASE_ANON_KEY
#
# Mises à jour Tauri (releases) — clés par projet dans src-tauri/signing/
#   mes-comptes.key      → privée, gitignorée, jamais sur GitHub
#   mes-comptes.key.pub  → publique (déjà dans tauri.conf.json)
#
# CI GitHub Actions (secrets, contenu du fichier .key + mot de passe) :
#   TAURI_SIGNING_PRIVATE_KEY
#   TAURI_SIGNING_PRIVATE_KEY_PASSWORD
#
# Build signé en local (PowerShell, depuis la racine du projet) :
#   $env:TAURI_SIGNING_PRIVATE_KEY = Get-Content -Raw "src-tauri/signing/mes-comptes.key"
#   $env:TAURI_SIGNING_PRIVATE_KEY_PASSWORD = "votre_mot_de_passe"
#   npm run build:desktop
# Signature APK Android (releases) :
#   ANDROID_KEYSTORE_BASE64
#   ANDROID_KEYSTORE_PASSWORD
#   ANDROID_KEY_ALIAS
